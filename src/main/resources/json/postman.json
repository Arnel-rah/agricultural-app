  "item": [
    {
      "name": "01 - Collectivités",
      "item": [
        {
          "name": "POST /collectivities - Créer une collectivité",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"location\": \"Antananarivo\",\n    \"members\": [\"C1-M1\", \"C1-M2\", \"C1-M3\", \"C1-M4\", \"C1-M5\", \"C1-M6\", \"C1-M7\", \"C1-M8\", \"C2-M1\", \"C2-M2\"],\n    \"federationApproval\": true,\n    \"structure\": {\n      \"president\": \"C1-M1\",\n      \"vicePresident\": \"C1-M2\",\n      \"treasurer\": \"C1-M4\",\n      \"secretary\": \"C1-M3\"\n    }\n  }\n]"
            },
            "url": { "raw": "http://localhost:8080/collectivities", "host": ["localhost"], "port": "8080", "path": ["collectivities"] }
          }
        },
        {
          "name": "GET /collectivities/{id} - Récupérer une collectivité",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8080/collectivities/col-1", "host": ["localhost"], "port": "8080", "path": ["collectivities", "col-1"] }
          }
        },
        {
          "name": "PUT /collectivities/{id}/informations - Attribuer nom et numéro",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mpanorina\",\n  \"number\": 1\n}" },
            "url": { "raw": "http://localhost:8080/collectivities/col-1/informations", "host": ["localhost"], "port": "8080", "path": ["collectivities", "col-1", "informations"] }
          }
        },
        {
          "name": "GET /collectivities/{id}/membershipFees - Lister les cotisations",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:8080/collectivities/col-1/membershipFees", "host": ["localhost"], "port": "8080", "path": ["collectivities", "col-1", "membershipFees"] }
          }
        },
        {
          "name": "POST /collectivities/{id}/membershipFees - Créer des cotisations",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"eligibleFrom\": \"2026-01-01\",\n    \"frequency\": \"MONTHLY\",\n    \"amount\": 10000,\n    \"label\": \"Cotisation mensuelle 2026\"\n  },\n  {\n    \"eligibleFrom\": \"2026-01-01\",\n    \"frequency\": \"WEEKLY\",\n    \"amount\": 2500,\n    \"label\": \"Cotisation hebdomadaire 2026\"\n  }\n]"
            },
            "url": { "raw": "http://localhost:8080/collectivities/col-1/membershipFees", "host": ["localhost"], "port": "8080", "path": ["collectivities", "col-1", "membershipFees"] }
          }
        },
        {
          "name": "GET /collectivities/{id}/transactions - Transactions sur période",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/collectivities/col-1/transactions?from=2026-01-01&to=2026-12-31",
              "host": ["localhost"], "port": "8080", "path": ["collectivities", "col-1", "transactions"],
              "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-12-31" }]
            }
          }
        },
        {
          "name": "GET /collectivities/{id}/financialAccounts - Comptes financiers",
          "request": {
            "method": "GET",
            "header": [],
