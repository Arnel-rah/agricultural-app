      "item": [
        {
          "name": "POST /members - Créer des membres",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"firstName\": \"Jean\",\n    \"lastName\": \"Rakoto\",\n    \"birthDate\": \"1990-01-01\",\n    \"gender\": \"MALE\",\n    \"address\": \"Lot Test 123 Antananarivo\",\n    \"profession\": \"Agriculteur\",\n    \"phoneNumber\": 341234567,\n    \"email\": \"jean.rakoto.nouveau@email.com\",\n    \"occupation\": \"JUNIOR\",\n    \"collectivityIdentifier\": null,\n    \"referees\": [\"C1-M1\", \"C1-M2\"],\n    \"registrationFeePaid\": true,\n    \"membershipDuesPaid\": true\n  }\n]"
